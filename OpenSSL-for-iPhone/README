taken from OpenSSL for iphone
https://github.com/x2on/OpenSSL-for-iPhone

built with:

git clone https://github.com/x2on/OpenSSL-for-iPhone.git
cd OpenSSL-for-iPhone

git checkout 1.1.1q

apply patch:

---
diff --git a/build-libssl.sh b/build-libssl.sh
index 94875f36..887af2b3 100755
--- a/build-libssl.sh
+++ b/build-libssl.sh
@@ -31,7 +31,7 @@ DEFAULTVERSION="1.1.1q"
 DEFAULTTARGETS="ios-sim-cross-x86_64 ios64-cross-arm64 ios64-cross-arm64e tvos-sim-cross-x86_64 tvos64-cross-arm64"  # mac-catalyst-x86_64 is a valid target that is not in the DEFAULTTARGETS because it's incompatible with "ios-sim-cross-x86_64"
 
 # Minimum iOS/tvOS SDK version to build for
-IOS_MIN_SDK_VERSION="15.0"
+IOS_MIN_SDK_VERSION="9.0"
 TVOS_MIN_SDK_VERSION="15.0"
 MACOSX_MIN_SDK_VERSION="12.1"

 
---

CONFIG_OPTIONS=" --api=1.0.0" ./build-libssl.sh --targets="ios-cross-armv7 ios64-cross-arm64 ios-sim-cross-i386 ios-sim-cross-x86_64" --deprecated

cp -r include/ ../include/
cp -r lib/* ../lib/


